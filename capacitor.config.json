{
  "appId": "com.desmondmifetu.osmosis",
  "appName": "Osmosis",
  "webDir": ".",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#f5f3ee",
    "minWebViewVersion": 60
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#f5f3ee"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#f5f3ee",
      "showSpinner": false
    }
  }
}
